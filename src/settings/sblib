#!/bin/sh
#
# Settings for the UNItopia mudlib.
#
# configure will strip this part from the script.

# --- The actual settings ---

# --- Runtime limits ---
with_max_array_size=10000
with_max_mapping_keys=10000
with_max_mapping_size=100000
with_max_byte_transfer=100000
with_read_file_max_size=100000
with_write_buffer_max_size=524288

# --- Timing ---
with_time_to_clean_up=5400
with_time_to_swap=1800
with_time_to_swap_variables=3600
with_time_to_reset=2400
with_alarm_time=1
with_heart_beat_interval=2
enable_synchronous_heart_beat=no

# --- Memory ---
with_reserved_user_size=0x400000
with_reserved_master_size=0x100000
with_reserved_system_size=0x200000
with_hard_malloc_limit=0x60000000
enable_min_malloced=yes
with_min_malloced=0x8000000
enable_min_small_malloced=yes
with_min_small_malloced=0x4000000

# --- Interpreter ---
enable_strict_euids=yes
with_max_cost=500000

# --- Communication ---
with_portno=4040
with_udp_port=4041
enable_use_ipv6=no
enable_use_anl=yes
enable_use_mccp=yes
enable_use_tls=gnu
with_tls_keyfile=no

#----------- Compilation Options ----------
enable_malloc_trace=yes
enable_malloc_lpc_trace=yes
enable_use_pthreads=no
enable_posix_timers=yes

# --- Wizlist ---
with_wizlist_file=WIZLIST

# --- Access Control ---
enable_access_control=no

# --- Language ---
enable_use_set_light=no
enable_use_parse_command=yes
enable_use_mysql=no
enable_use_sqlite=no
enable_use_pgsql=no
enable_use_xml=xml2
enable_use_deprecated=no
enable_use_pcre=no
enable_lpc_array_calls=yes
enable_use_python=yes
enable_keyword_in=yes

# --- Runtime limits ---
with_catch_reserved_cost=0x10000
with_master_reserved_cost=0x4000
enable_dynamic_costs=yes
enable_eval_cost_trace=yes
with_max_trace=80
with_max_players=200

# --- Compiler ---

# --- Internal Tables ---
with_htable_size=0x10000
with_otable_size=0x4000
with_apply_cache_bits=14

# --- Profiling ---

# --- Standard Debugging ---
enable_check_strings=no

# --- Specific Debugging ---
enable_check_object_stat=no

# --- Additional tools ---
enable_erq=xerq

enable_use_process_string=yes

enable_debug=yes
enable_trace_code=yes
erq_debug=0
enable_debug_telnet=no
enable_yydebug=no
enable_check_object_ref=yes

#
# Settings file for Silver Bucket Mudlib
# This file configures the LDMud driver for use with the sblib mudlib
#

# Enable debugging features
#define DEBUG
#define DEBUG_TELNET

# Memory and performance settings
#define MAX_COST                1000000
#define CATCH_RESERVED_COST     2000
#define MASTER_RESERVED_COST    512
#define MAX_ARRAY_SIZE          5000
#define MAX_MAPPING_SIZE        15000
#define MAX_MAPPING_KEYS        3000
#define MAX_CALLOUTS            1000
#define MAX_PLAYERS             50

# Enable features commonly used in mudlibs
#define USE_BUILTIN_EDITOR
#define USE_SWAP
#define USE_SYSTEM_CRYPT
#define USE_PARSE_COMMAND
#define USE_PROCESS_STRING
#define USE_STRUCTS
#define USE_NEW_INLINES
#define USE_CLOSURE_SPECIALIZER

# Network settings
#define USE_IPV6
#define USE_MCCP
#define ERQ_INCLUDE_FILE_ACCESS
#define ERQ_INCLUDE_EXECUTE

# Enable advanced string and array functions
#define USE_EXPERIMENTAL
#define USE_DEPRECATED

# Wizard features
#define WIZLIST_FILE            "/WIZLIST"

# Default runtime limits
#define DEF_EVAL_COST           200000
#define DEF_MAX_EVAL_COST       2000000

# File system settings
#define MAX_SAVE_OBJECT_RECURSION 50

# Enable PCRE regular expressions
#define HAS_PCRE

# Enable XML support if available
#define HAS_XML

# Python integration (if ldmud-python is available)
#define HAS_PYTHON

# Security settings
#define RESTRICTED_FILE_WRITE
#define RESTRICTED_ED

# Optimize for mudlib usage
#define OPTIMIZE_FUNCTION_CALLS
#define USE_BUILTIN_EDITOR
